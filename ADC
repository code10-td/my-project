POT-HG,VIRTUAL TERMINAL,VOLT-METER

unsigned int adc_value;
char txt [7];

void main(){
TRISA=0XFF;
TRISC=0X80;
UART1_init(9600);
delay_ms(1000);

while(1){
 adc_value=ADC_READ(0);
 inttostr(adc_value,txt);
 UART1_Write_Text("ADC VALUE:");
 UART1_Write_Text(txt);
 UART1_Write_Text("\r\n");
 delay_ms(1000);
 
 }
}
